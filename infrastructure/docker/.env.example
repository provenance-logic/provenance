# Provenance Docker Compose environment — copy to .env and fill in values.
# Never commit .env to version control.

# PostgreSQL (shared instance — used by provenance API, Keycloak, and Kong)
POSTGRES_PASSWORD=provenance_dev_password

# Neo4j
NEO4J_PASSWORD=provenance_dev_password

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=provenance
MINIO_ROOT_PASSWORD=provenance_dev_password

# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=provenance_dev_admin

# Keycloak client secrets (generated after Keycloak is configured)
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_AGENT_CLIENT_SECRET=

# MCP API key (authenticates requests between API and agent-query)
# Generate with: openssl rand -hex 32
# Rotate every 90 days. Never reuse a key from git history.
MCP_API_KEY=

# Default organization ID (used by agent-query when no org context is provided)
DEFAULT_ORG_ID=

# Anthropic API key (used by agent-query for NL query translation)
# Required for Phase 4 agent features. Leave empty for Phase 1.
ANTHROPIC_API_KEY=

# Port connection-details encryption (Domain 10 Workstream B — F10.6).
# One of the two must be set or the API will refuse to boot.
#
# Production: set CONNECTION_DETAILS_SECRET_ARN to an AWS Secrets Manager
# ARN holding a 32-byte AES key (hex-encoded). The API reads the secret
# at first use and caches it in memory.
#
# Dev / demo: set CONNECTION_DETAILS_DEV_KEY to a 64-char hex string. The
# default below is a throwaway key for local dev only — any connection
# details encrypted with it are effectively unprotected. Never use this
# value outside a disposable dev environment.
# Generate a fresh key with: openssl rand -hex 32
CONNECTION_DETAILS_SECRET_ARN=
CONNECTION_DETAILS_DEV_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# ----- Seed API (Phase 5.6 — dev experience) ----------------------------------
# Mounts the /api/v1/seed/* controller used by the @provenance/seed package's
# runner to populate orgs, domains, principals, policies, products, agents,
# and lineage in a fresh stack. Endpoints require an x-seed-service-token
# header that is constant-time-compared to SEED_API_KEY.
#
# Production must NEVER set SEED_ENABLED=true. The seed surface bypasses
# JWT auth and trusts the caller's claimed identity for the seed payload.
SEED_ENABLED=true
SEED_API_KEY=dev-seed-token-change-me
