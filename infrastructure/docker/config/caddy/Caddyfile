dev.provenancelogic.com {
	# Caddy automatically obtains and renews TLS certificates from Let's Encrypt
	# and redirects HTTP → HTTPS by default.

	# API control plane — preserves /api/* path (NestJS serves routes under /api/v1/*)
	handle /api/* {
		reverse_proxy api:3001
	}

	# MCP / agent query layer — preserves /mcp/* path
	handle /mcp/* {
		reverse_proxy agent-query:3002
	}

	# Keycloak OIDC — preserves /auth/* path (Keycloak realm paths live under /auth/ or /realms/)
	handle /auth/* {
		reverse_proxy keycloak:8080
	}

	# React frontend (default)
	handle {
		reverse_proxy web:3000
	}
}

auth.provenancelogic.com {
	# Caddy automatically obtains and renews TLS certificates from Let's Encrypt
	# and redirects HTTP → HTTPS by default. Keycloak serves /realms/*,
	# /resources/*, and /admin/* natively at root — no path handling needed.
	#
	# Explicit header_up directives so Keycloak (KC_PROXY=edge) generates
	# https:// URLs and sets Secure cookies. Caddy v2 sets these by default,
	# but we keep them explicit for clarity and robustness against config drift.
	reverse_proxy keycloak:8080 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-For {remote_host}
	}
}
