# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Turbo
.turbo/

# Environment files — never commit secrets
.env
.env.local
.env.*.local
.env.ec2
# Allow the example file
!.env.example

# Coverage
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Docker
infrastructure/docker/config/keycloak/realms/*.json
!infrastructure/docker/config/keycloak/realms/.gitkeep

# Local backup archives (created by infrastructure/scripts/backup.sh)
backups/

# Terraform state — never commit state files
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/dev/.terraform/
infrastructure/terraform/dev/*.tfstate
infrastructure/terraform/dev/*.tfstate.backup
