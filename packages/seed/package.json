{
  "name": "@provenance/seed",
  "version": "0.1.0",
  "private": true,
  "description": "Seed data package for demo and dev environments — orgs, policies, users, products, agents, lineage",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "seed": "tsx src/cli.ts seed",
    "seed:reset:soft": "tsx src/cli.ts reset --soft",
    "seed:reset:hard": "tsx src/cli.ts reset --hard",
    "seed:verify": "tsx src/cli.ts verify"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.6",
    "tsx": "^4.15.7",
    "typescript": "^5.4.0"
  }
}
